################################################################################
# Atom-atom electronic relaxation in a 0-D thermal reservoir
#
# Pure atomic oxygen in a box: translation starts hot (30000 K) while the
# electronic mode starts cold (all atoms in the ground state, T_elec = 100 K).
# Atomic O has zero rotational and vibrational degrees of freedom, so the
# electronic mode can only relax through atom-atom collisions. Over the run
# the electronic states populate toward a Boltzmann distribution and the
# translational and electronic temperatures approach a common value.
#
# Note:
#  - The "comm/sort" option to the "global" command is used to match MPI runs.
#  - The "twopass" option is used to match Kokkos runs.
# The "comm/sort" and "twopass" options should not be used for production runs.
################################################################################

seed		    12345
dimension   	    3
global              gridcut 1.0e-5 comm/sort yes

boundary	    rr rr rr

create_box  	    0 0.0001 0 0.0001 0 0.0001
create_grid 	    2 2 2

balance_grid        rcb part

species		    air.species O elecfile air.elec
mixture		    gas O vstream 0.0 0.0 0.0 temp 30000.0 telec 100.0

global              nrho 1.4141E24
global              fnum 3.5352E7

collide		    vss gas air.vss relax constant
collide_modify      rotate no vibrate no electronic discrete
fix                 electronic elecmode
collide_modify      remain no

create_particles    gas n 40000 twopass

compute             temp temp
compute             T thermal/grid all all temp
compute             Ttrans reduce ave c_T[1]

compute             elec grid all species eelec
compute             Eelec reduce ave c_elec[1]

compute             telec telec/grid all species
compute             Telec reduce ave c_telec[*]

stats		    200
stats_style	    step cpu np nattempt ncoll c_Ttrans c_Eelec c_Telec

timestep 	    1.00E-9
run 		    4000
