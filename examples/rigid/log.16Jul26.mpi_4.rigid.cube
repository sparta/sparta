SPARTA (24 Sep 2025)
Running on 4 MPI task(s)
################################################################################
# 3d flow around a mobile rigid-body cube
#
# a cubic particulate, rotated off-axis to the flow, is embedded in a
# free-stream flow: particle collisions push it downstream and
# exert a torque which makes it tumble
#
# Note:
#  - The "comm/sort" option to the "global" command is used to match MPI runs.
#  - The "twopass" option is used to match Kokkos runs.
# The "comm/sort" and "twopass" options should not be used for production runs.
################################################################################

seed	    	    12345
dimension   	    3
global              gridcut 0.0 comm/sort yes

boundary	    o r r

create_box  	    0 10 0 10 0 10
Created orthogonal box = (0 0 0) to (10 10 10)
create_grid 	    10 10 10
WARNING: Could not acquire nearby ghost cells b/c grid partition is not clumped (../grid.cpp:473)
Created 1000 child grid cells
  CPU time = 0.00089087 secs
  create/ghost percent = 91.1355 8.86448
balance_grid        rcb cell
Balance grid migrated 740 cells
  CPU time = 0.000587701 secs
  reassign/sort/migrate/ghost percent = 48.2376 0.294538 26.8637 24.6042

global		    nrho 1.0 fnum 0.01

species		    air.species N O
mixture		    air N O vstream 100.0 0 0

# unit cube centered at (5,5,5), rotated 30 degrees about z,
# treated as a mobile rigid body

read_surf           sdata.cube group cube rotate 30 0 0 1 trans 5 5 5
  12 triangles
  4.31699 5.68301 xlo xhi
  4.31699 5.68301 ylo yhi
  4.5 5.5 zlo zhi
  1 min triangle edge length
  0.5 min triangle area
  8 0 = cells overlapping surfs, overlap cells with unmarked corner pts
  992 0 8 = cells outside/inside/overlapping surfs
  8 = surf cells with 1,2,etc splits
  999 999 = cell-wise and global flow volume
  CPU time = 0.000847705 secs
  read/check/sort/surf2grid/ghost/inout/particle percent = 4.9739 30.162 0.762647 45.5617 18.5397 10.6484 0.0941365
  surf2grid time = 0.000386229 secs
  map/comm1/comm2/comm3/comm4/split percent = 24.0886 5.09361 7.40726 2.95938 29.7541 21.0202

surf_collide	    1 diffuse 300.0 0.0
surf_modify         all collide 1

collide             vss air air.vss

fix		    in emit/face air xlo twopass

timestep 	    0.0001

# per-surf force/torque tallies used to move the rigid body
# moi of a uniform cube of edge A is isotropic: 1/6 M A^2 on the diagonal,
# which is the same in any orientation

compute             csurf surf cube all fx fy fz tx ty tz com 5 5 5

global              rigid 1

fix		    1 rigid cube csurf body                     mass 3.0e-21 com 5 5 5 vcom 0 0 0                     moi 5.0e-22 5.0e-22 5.0e-22 0 0 0 angmom 0 0 0

stats		    100
stats_style	    step cpu np nscoll f_1[1] f_1[4] f_1[13] f_1[14] f_1[15]
run 		    1000
