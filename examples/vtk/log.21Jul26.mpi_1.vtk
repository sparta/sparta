SPARTA (24 Sep 2025)
Running on 1 MPI task(s)
# 2d flow around a circle, writing native VTK dump files
# exercises dump particle/vtk, grid/vtk, and surf/vtk (VTK package)

seed        12345
dimension   2
global      gridcut 0.0 comm/sort yes

boundary    o r p

create_box  0 10 0 10 -0.5 0.5
Created orthogonal box = (0 0 -0.5) to (10 10 0.5)
create_grid 20 20 1
Created 400 child grid cells
  CPU time = 0.00101416 secs
  create/ghost percent = 90.01 9.99001
balance_grid rcb cell
Balance grid migrated 0 cells
  CPU time = 0.000144479 secs
  reassign/sort/migrate/ghost percent = 59.1823 0.521875 9.92878 30.367

global      nrho 1.0 fnum 0.001

species     air.species N O
mixture     air N O vstream 100.0 0 0

read_surf   data.circle
  50 lines
  2 8 xlo xhi
  2.00592 7.99408 ylo yhi
  0 0 zlo zhi
  0.376743 min line length
  48 0 = cells overlapping surfs, overlap cells with unmarked corner pts
  264 88 48 = cells outside/inside/overlapping surfs
  48 = surf cells with 1,2,etc splits
  71.8 71.8 = cell-wise and global flow volume
  CPU time = 0.000614361 secs
  read/check/sort/surf2grid/ghost/inout/particle percent = 7.34975 15.9613 2.29246 65.673 8.72354 5.80945 0.0200208
  surf2grid time = 0.000403469 secs
  map/comm1/comm2/comm3/comm4/split percent = 28.0287 6.08498 10.3051 2.43265 44.129 6.56358
surf_collide 1 diffuse 300.0 0.0
surf_modify all collide 1

collide     vss air air.vss

fix         in emit/face air xlo twopass

timestep    0.0001

# VTK dumps: particles as points, grid cells as pixels, surf as lines
# '*' in the filename is required (one file per timestep)
# use '%' (e.g. tmp.grid.%.*.vtu) for per-processor pieces + a .pvtu summary

dump        1 particle/vtk air 250 tmp.particle.*.vtu id type x y z vx vy vz
dump        2 grid/vtk     all 250 tmp.grid.*.vtu     id proc vol
dump        3 surf/vtk     all 250 tmp.surf.*.vtp     id type

stats       250
stats_style step cpu np nattempt ncoll nscoll nscheck
run         500
