# TEST: remap mode consistency
# pseudo-particle-driven body, no real particles: the trajectory is
# deterministic and must be identical for remap cutcell and
# incremental, since the remap method must not alter the dynamics
# run as: spa_serial -in in.test.remap -var mode cutcell   (or incremental)

seed	    	    12345
dimension   	    2

create_box  	    0 10 0 10 -0.5 0.5
create_grid 	    10 10 1

global		    nrho 1.0 fnum 0.001

species		    air.species N
mixture		    air N vstream 100.0 0 0

read_surf           data.square group body
surf_collide	    1 diffuse 300.0 0.0
surf_modify         all collide 1

timestep 	    0.0001

compute             c1 surf body all fx fy fz tx ty tz com 5 5 0

global              rigid yes

fix		    1 rigid body c1 body &
		    mass 1.0 com 5 5 0 vcom 0 0 0 &
                    moi 0.083333333 0.083333333 0.166666667 0 0 0 &
                    angmom 0 0 0 &
		    pseudo 10 100.0 0.2 remap ${mode}

stats		    50
stats_style         step f_1[1] f_1[2] f_1[4] f_1[15]
run 		    200
