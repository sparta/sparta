# TEST: gas + body momentum conservation
# fully periodic box, drifting gas, body initially at rest
# total x momentum = m_N * fnum * sum(vx) + M * vcm_x must be conserved
# to statistical noise as the gas pushes the body

seed	    	    12345

variable            dist index 0
if "${dist} == 1" then "global surfs explicit/distributed"
dimension   	    2
boundary            p p p

create_box  	    0 10 0 10 -0.5 0.5
create_grid 	    20 20 1

global		    nrho 1.0 fnum 0.001

species		    air.species N
mixture		    air N vstream 100.0 0 0 temp 273.0

read_surf           data.square group body
surf_collide	    1 specular
surf_modify         all collide 1

timestep 	    0.0001

compute             c1 surf body all fx fy fz tx ty tz com 5 5 0

global              rigid yes

fix		    1 rigid body c1 body &
		    mass 1.0e-22 com 5 5 0 vcom 0 0 0 &
		    moi 1.7e-23 1.7e-23 3.4e-23 0 0 0 angmom 0 0 0

create_particles    air n 20000

variable px particle vx
compute r reduce sum v_px

stats		    200
stats_style         step np c_r f_1[4] f_1
run 		    2000
