# NEGATIVE TEST: body group which is not a closed object
# 3 of the square's 4 lines form an open polyline:
# fix rigid must reject it with a watertight error

seed	    	    12345
dimension   	    2
boundary            o o p

create_box  	    0 10 0 10 -0.5 0.5
create_grid 	    10 10 1

global		    nrho 1.0 fnum 0.001

species		    air.species N
mixture		    air N vstream 0 0 0 temp 273.0

read_surf           data.square
group               partial surf id 1 2 3
surf_collide	    1 specular
surf_modify         all collide 1

timestep 	    0.0001

compute             c1 surf partial all fx fy fz tx ty tz com 5 5 0

global              rigid yes

fix		    1 rigid partial c1 body &
		    mass 1.0e-22 com 5 5 0 vcom 0 0 0 &
		    moi 1.7e-23 1.7e-23 3.4e-23 0 0 0 angmom 0 0 0

run 		    10
