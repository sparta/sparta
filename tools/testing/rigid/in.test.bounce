# TEST: rigid body bouncing off a static wall via push-off forces
# no particles: deterministic on any number of procs
# body launched at +50 m/s must rebound at ~-50 m/s (energy conserved)
# and must never tunnel into the push-off cutoff region past the spring
# run as: -var pstyle linear -var pk 1.0e-18   (or hertz / 4.0e-18)

seed	    	    12345
dimension   	    2
boundary            r r p

create_box  	    0 10 0 10 -0.5 0.5
create_grid 	    20 20 1

global		    nrho 1.0 fnum 0.001

species		    air.species N
mixture		    air N vstream 0 0 0 temp 273.0

read_surf           data.square group body
read_surf           data.wall group wall
surf_collide	    1 specular
surf_modify         all collide 1

timestep 	    0.0001

compute             c1 surf body all fx fy fz tx ty tz com 5 5 0

global              rigid yes

fix		    1 rigid body c1 body &
		    mass 1.0e-22 com 5 5 0 vcom 50 0 0 &
		    moi 8.3333333e-24 8.3333333e-24 1.6666667e-23 0 0 0 &
                    angmom 0 0 0 &
		    push ${pk} 0.5 pushstyle ${pstyle}

stats		    50
stats_style         step f_1[1] f_1[4] f_1[15]
run 		    1500
