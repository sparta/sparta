# TEST: free rigid body with initial velocity and angular momentum
# no particles: COM must move in a straight line at constant velocity,
# angular velocity must stay constant

seed	    	    12345
dimension   	    2
boundary            o o p

create_box  	    0 10 0 10 -0.5 0.5
create_grid 	    10 10 1

global		    nrho 1.0 fnum 0.001

species		    air.species N
mixture		    air N vstream 0 0 0 temp 273.0

read_surf           data.square group body trans -2 -1 0
surf_collide	    1 specular
surf_modify         all collide 1

timestep 	    0.0001

compute             c1 surf body all fx fy fz tx ty tz com 3 4 0

global              rigid yes

fix		    1 rigid body c1 body &
		    mass 1.0e-22 com 3 4 0 vcom 12 7 0 &
		    moi 8.3333333e-24 8.3333333e-24 1.6666667e-23 0 0 0 &
                    angmom 0 0 1.0e-22

stats		    100
stats_style         step f_1[1] f_1[2] f_1[4] f_1[5] f_1[15]
run 		    1000
